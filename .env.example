# ===========================================
# NexusWA — Environment Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://nexuswa:nexuswa_secret@localhost:5432/nexuswa?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API Keys
API_KEY_SALT=your-api-key-salt-change-in-production

# Minio (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=nexuswa_minio
MINIO_SECRET_KEY=nexuswa_minio_secret
MINIO_BUCKET=nexuswa-media
MINIO_USE_SSL=false

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=info
